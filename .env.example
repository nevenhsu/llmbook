NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="your-anon-or-publishable-key"

# Supabase server access
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
SUPABASE_STORAGE_BUCKET="media"

# Direct Postgres (pooler) for atomic transactions via pg.
# Use sslmode=verify-full in normal usage.
POSTGRES_URL="postgresql://postgres.your-project-ref:your-password@aws-1-us-east-1.pooler.supabase.com:6543/postgres?sslmode=verify-full"
# Optional custom CA bundle for Node TLS (validated by scripts/run-next.sh when set)
NODE_EXTRA_CA_CERTS="/Users/your-user/.certs/supabase-ca-bundle.pem"

# Local test account
TEST_USER_EMAIL=""
TEST_USER_PASSWORD=""

# LLM provider runtime (SDK-first: ai + @ai-sdk/xai)
# Main model/provider route should be managed in DB control plane.
AI_MODEL_TIMEOUT_MS="20000"
AI_MODEL_RETRIES="1"
# Runtime fallback default target when DB active-order route is unavailable.
# AI_DEFAULT_PROVIDER_ID: xai | minimax
AI_DEFAULT_PROVIDER_ID="xai"
# Examples:
# - xai: grok-4-1-fast-reasoning
# - minimax: MiniMax-M2.1
AI_DEFAULT_MODEL_ID="grok-4-1-fast-reasoning"
# Provider-specific registration defaults
# AI_DEFAULT_XAI_MODEL_ID examples: grok-4-1-fast-reasoning, grok-imagine-image
AI_DEFAULT_XAI_MODEL_ID="grok-4-1-fast-reasoning"
# AI_DEFAULT_MINIMAX_MODEL_ID examples: MiniMax-M2.1
AI_DEFAULT_MINIMAX_MODEL_ID="MiniMax-M2.1"

# Optional provider API key fallback for development only.
# Runtime priority: Supabase encrypted secrets table > env fallback.
XAI_API_KEY=""
MINIMAX_API_KEY=""

# Encryption key for provider secrets stored in Supabase (`ai_provider_secrets`).
# Accepts either raw string (sha256 derived) or base64-encoded 32-byte key.
AI_PROVIDER_SECRET_ENCRYPTION_KEY=""
