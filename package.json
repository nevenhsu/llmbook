{
  "name": "persona-sandbox",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.0.0",
  "engines": {
    "node": ">=22",
    "pnpm": ">=11"
  },
  "scripts": {
    "dev": "bash scripts/run-next.sh dev",
    "build": "bash scripts/run-next.sh build",
    "start": "bash scripts/run-next.sh start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "next typegen && tsc --noEmit --pretty false",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "test": "vitest run",
    "test:core": "vitest run src/lib/ai/prompt-runtime/prompt-builder.test.ts src/lib/ai/prompt-runtime/post-plan-contract.test.ts src/lib/ai/prompt-runtime/post-body-audit.test.ts src/lib/ai/prompt-runtime/comment-flow-audit.test.ts src/lib/ai/prompt-runtime/reply-flow-audit.test.ts src/lib/ai/admin/persona-generation-contract.test.ts src/lib/ai/agent/execution/persona-task-generator.test.ts src/lib/ai/agent/execution/flows/post-flow-module.test.ts src/lib/ai/agent/execution/flows/comment-flow-module.test.ts src/lib/ai/agent/execution/flows/reply-flow-module.test.ts",
    "test:llm-flows": "vitest run src/lib/ai/prompt-runtime/action-output.test.ts src/lib/ai/prompt-runtime/json-parse-utils.test.ts src/lib/ai/prompt-runtime/prompt-builder.test.ts src/lib/ai/prompt-runtime/persona-prompt-directives.test.ts src/lib/ai/prompt-runtime/post-plan-contract.test.ts src/lib/ai/prompt-runtime/post-plan-audit.test.ts src/lib/ai/prompt-runtime/post-body-audit.test.ts src/lib/ai/prompt-runtime/comment-flow-audit.test.ts src/lib/ai/prompt-runtime/reply-flow-audit.test.ts src/lib/ai/prompt-runtime/runtime-budgets.test.ts src/lib/ai/admin/persona-generation-contract.test.ts src/lib/ai/admin/persona-generation-prompt-template.test.ts src/lib/ai/admin/control-plane-store.persona-generation-preview.test.ts src/lib/ai/core/runtime-core-profile.test.ts src/lib/ai/agent/execution/persona-interaction-service.test.ts src/lib/ai/agent/execution/persona-task-generator.test.ts src/lib/ai/agent/execution/persona-task-persistence-service.test.ts src/lib/ai/agent/execution/flows/post-flow-module.test.ts src/lib/ai/agent/execution/flows/comment-flow-module.test.ts src/lib/ai/agent/execution/flows/reply-flow-module.test.ts",
    "test:watch": "vitest",
    "verify": "npm run typecheck && npm run lint && npm run test:llm-flows",
    "ai:phase-a:once": "rm -rf logs/manual-prompts && npm run -s script:run -- src/agents/orchestrator/phase-a-once.ts",
    "ai:jobs-runtime:start": "npm run -s script:run -- src/agents/jobs-runtime/runner.ts",
    "script:run": "ts-node -r ./scripts/register-env.ts -r tsconfig-paths/register",
    "cron:rankings": "npm run -s script:run -- scripts/cron-manager.ts --rankings-only"
  },
  "dependencies": {
    "@ai-sdk/deepseek": "^2.0.32",
    "@ai-sdk/xai": "^3.0.88",
    "@dicebear/collection": "^9.4.2",
    "@dicebear/core": "^9.4.2",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@floating-ui/react": "^0.27.19",
    "@inquirer/prompts": "^8.4.2",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.105.3",
    "@tiptap/core": "^3.22.5",
    "@tiptap/extension-highlight": "^3.22.5",
    "@tiptap/extension-horizontal-rule": "^3.22.5",
    "@tiptap/extension-image": "^3.22.5",
    "@tiptap/extension-link": "^3.22.5",
    "@tiptap/extension-list": "^3.22.5",
    "@tiptap/extension-mention": "^3.22.5",
    "@tiptap/extension-placeholder": "^3.22.5",
    "@tiptap/extension-subscript": "^3.22.5",
    "@tiptap/extension-superscript": "^3.22.5",
    "@tiptap/extension-text-align": "^3.22.5",
    "@tiptap/extension-typography": "^3.22.5",
    "@tiptap/extensions": "^3.22.5",
    "@tiptap/markdown": "^3.22.5",
    "@tiptap/pm": "^3.22.5",
    "@tiptap/react": "^3.22.5",
    "@tiptap/starter-kit": "^3.22.5",
    "ai": "^6.0.175",
    "dompurify": "^3.4.2",
    "isomorphic-dompurify": "^3.12.0",
    "lodash-es": "^4.18.1",
    "lodash.throttle": "^4.1.1",
    "lucide-react": "^1.14.0",
    "next": "16.2.4",
    "pg": "^8.20.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-hot-toast": "^2.6.0",
    "react-hotkeys-hook": "^5.3.1",
    "sharp": "^0.34.5",
    "tippy.js": "^6.3.7",
    "transliteration": "^2.6.1",
    "uuid": "^14.0.0",
    "vercel-minimax-ai-provider": "^0.0.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.4",
    "@types/dompurify": "^3.2.0",
    "@types/lodash-es": "^4.17.12",
    "@types/lodash.throttle": "^4.1.9",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^11.0.0",
    "autoprefixer": "^10.5.0",
    "daisyui": "^5.5.19",
    "dotenv": "^17.4.2",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.4",
    "husky": "^9.1.7",
    "postcss": "^8.5.14",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "sass": "^1.99.0",
    "tailwindcss": "^4.2.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
